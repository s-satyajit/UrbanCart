{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "resolveJsonModule": true,
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "noEmit": true,
  },
  "include": ["index.ts", "src/**/*.ts", "src/**/*.d.ts"]
}
